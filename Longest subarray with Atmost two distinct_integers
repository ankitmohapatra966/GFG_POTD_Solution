class Solution {
  public:
    virtual int totalElements(vector<int> &arr) {
      unordered_map<int, int> um;
      int i=0;
      int n=arr.size();
      
      int ans=0;
      
      for(int j=0; j<n; j++){
        um[arr[j]]++;
        while(um.size()>2){
          um[arr[i]]--;
          if(um[arr[i]]==0) um.erase(arr[i]);
          i++;
        }
        
        ans = max(ans, j-i+1);
      }
      
      return ans;
    }
};

